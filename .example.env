# ============================================
# NFX-Vault 环境变量配置示例
# ============================================
# 复制此文件为 .env 并根据实际情况修改配置
# cp .example.env .env

# ============================================
# Docker Compose 发布端口（格式：IP:宿主机端口:容器内端口）
# 后端容器内 uvicorn 监听 8000；前端 nginx 监听 80
# ============================================
BACKEND_HOST=192.168.1.64
BACKEND_PORT=10151
FRONTEND_HOST=192.168.1.64
FRONTEND_PORT=10152

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_HOST=192.168.1.64
MYSQL_DATABASE_PORT=3306
MYSQL_DATABASE=nfxvault
MYSQL_ROOT_USERNAME=root
MYSQL_ROOT_PASSWORD=your_mysql_password

# ============================================
# Redis 缓存配置
# ============================================
REDIS_HOST=192.168.1.64
REDIS_DATABASE_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password
REDIS_CACHE_TTL=3600

# ============================================
# Kafka 消息队列配置
# ============================================
KAFKA_BOOTSTRAP_SERVERS=192.168.1.64:9092
KAFKA_EVENT_TOPIC=nfxvault.cert_server
KAFKA_EVENT_POISON_TOPIC=nfxvault.cert_server.poison
KAFKA_CONSUMER_GROUP_ID=nfxvault-cert-server

# ============================================
# 用户头像与上传暂存（data/tmp、data/avatar，与 Pqttec tmp→avatar 一致）
# ============================================
# Docker Compose：仅表示宿主机绑定目录（相对 compose 项目目录的 ./data，或绝对路径）；容器内固定为 /vault-data（compose 已写死，勿填相对路径作挂载目标）。
# 本地直接跑 uvicorn（无 Docker）：相对路径相对于仓库 NFX-Vault 根；不设则默认仓库下 data/
VAULT_DATA_DIR=./data

# ============================================
# 前端 API 基路径（docker compose build args / 本地 Vite）
# ============================================
# 同域反代：/vault；直连后端示例：http://192.168.1.64:10151/vault
VITE_API_URL=/vault

# ============================================
# 证书管理配置
# ============================================
# 证书存储根目录
CERTS_DIR=/home/kali/repo

# ACME 挑战文件存储目录
ACME_CHALLENGE_DIR=/tmp/acme-challenges

# 证书申请最大等待时间（秒）
CERT_MAX_WAIT_TIME=360

# ============================================
# 启动和调度配置
# ============================================
# 启动时是否读取文件夹并存储到数据库
READ_ON_STARTUP=true

# 是否启用定时任务（仅每日 01:00 根据 not_after 更新剩余天数，不读磁盘目录）
SCHEDULE_ENABLED=true

# ============================================
# 邮箱配置（发送验证码，与 PQTTEC 一致）
# ============================================
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=example@gmail.com
EMAIL_SMTP_PASSWORD=exampleexample

# ============================================
# JWT / 验证码（Redis TTL）
# ============================================
# 生产环境必须设置强随机 JWT_SECRET
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
# 邮箱验证码在 Redis 中的过期时间（秒），默认 600=10 分钟
EMAIL_VERIFICATION_CODE_TTL_SECONDS=600

# ============================================
# 注意
# ============================================
# 1. 更新剩余天数的任务固定为每天凌晨 1:00 执行（不可配置）
# 2. 所有布尔值使用小写 true/false
# 3. 生产环境请修改所有默认密码
# 4. 确保 CERTS_DIR 和 ACME_CHALLENGE_DIR 目录存在且有正确权限
