# ============================================
# Certs 证书管理项目 .gitignore
# ============================================

# 环境配置文件（包含实际配置信息）
.env

# 证书文件（敏感信息）
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
acme.json

# Certbot 工作目录（包含配置、日志、证书等）
.certbot/

# 证书存储文件（敏感信息）
# 忽略 Websites 和 Apis 目录下的所有内容（包含证书和密钥）
# 但保留目录本身和 .gitkeep 文件
Websites/*
!Websites/.gitkeep
Apis/*
!Apis/.gitkeep

# 导出的证书文件
exported/
*.crt
*.key

# 日志文件
*.log
logs/
*.log.*

# 备份文件
*.bak
*.backup
*.old
*.tmp
*~

# 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# 编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# 临时文件
*.tmp
*.temp
.cache/

# ============================================
# NFX-Vault Web 服务相关
# ============================================

# Python 虚拟环境（仓库内任意路径，含 backend/、根目录等）
venv/
.venv/
env/
ENV/

# 前端
frontend/node_modules/
frontend/dist/
frontend/dist-ssr
frontend/*.local
frontend/.env.local
frontend/.env.*.local
frontend/logs
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*

# 后端
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/*.pyo
backend/*.pyd
backend/*.so
backend/.Python
backend/.env
backend/.env.local
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/dist/
backend/build/
backend/*.egg-info/

# Root still holds certs & compose; keep IDE ignores generic
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

